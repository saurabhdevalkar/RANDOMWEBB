---
import type { Website } from '../data/websites';
import { categories } from '../data/categories';

const { site } = Astro.props as { site: Website };
const cat = categories.find(c => c.slug === site.category);
---

<div style="border:1px solid #444444;background:#161616;padding:24px;">
  <div style="font-family:'Courier New',monospace;font-size:0.58rem;letter-spacing:0.2em;text-transform:uppercase;color:#484038;margin-bottom:12px;">— Featured Today —</div>
  <div style="display:flex;gap:16px;align-items:flex-start;flex-wrap:wrap;">
    <div style="font-size:2.5rem;flex-shrink:0;filter:grayscale(1);opacity:0.7;">{cat?.icon ?? '🌐'}</div>
    <div style="flex:1;min-width:180px;">
      <h2 style="font-family:'Special Elite',serif;font-size:1.3rem;color:#e8e0d0;letter-spacing:0.05em;margin:0 0 8px;">{site.title}</h2>
      <p style="font-family:'Courier New',monospace;font-size:0.72rem;color:#706860;line-height:1.7;margin:0 0 14px;">{site.description}</p>
      <div style="display:flex;flex-wrap:wrap;gap:4px;margin-bottom:16px;">
        {site.tags.map(tag => (
          <span style="font-family:'Courier New',monospace;font-size:0.55rem;letter-spacing:0.1em;text-transform:uppercase;color:#484038;border:1px solid #1e1e1e;padding:1px 5px;">{tag}</span>
        ))}
      </div>
      <a href={site.url} target="_blank" rel="noopener noreferrer" class="btn-primary">
        Visit {site.title} →
      </a>
    </div>
  </div>
</div>
