---
import type { Website } from '../data/websites';
import { categories } from '../data/categories';

interface Props {
  site: Website;
  compact?: boolean;
}

const { site, compact = false } = Astro.props;
const cat = categories.find(c => c.slug === site.category);
const stars = Math.round(site.rating);
---

<article style="background:#161616;border:1px solid #2a2a2a;padding:16px;display:flex;flex-direction:column;gap:10px;transition:border-color 0.15s;"
  onmouseover="this.style.borderColor='#c8b898'" onmouseout="this.style.borderColor='#2a2a2a'">
  <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:8px;">
    <div style="min-width:0;">
      <h3 style="font-family:'Special Elite',serif;font-size:0.85rem;color:#e8e0d0;letter-spacing:0.04em;margin:0 0 2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">{site.title}</h3>
      <p style="font-family:'Courier New',monospace;font-size:0.58rem;color:#484038;letter-spacing:0.06em;margin:0;">{new URL(site.url).hostname}</p>
    </div>
    <div style="display:flex;gap:4px;flex-shrink:0;">
      {site.trending && <span style="font-family:'Courier New',monospace;font-size:0.55rem;letter-spacing:0.1em;color:#c8a860;border:1px solid #444028;padding:1px 5px;text-transform:uppercase;">Hot</span>}
      {site.recentlyAdded && <span style="font-family:'Courier New',monospace;font-size:0.55rem;letter-spacing:0.1em;color:#a0a890;border:1px solid #284028;padding:1px 5px;text-transform:uppercase;">New</span>}
    </div>
  </div>

  {!compact && (
    <p style="font-family:'Courier New',monospace;font-size:0.68rem;color:#706860;line-height:1.6;margin:0;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;">{site.description}</p>
  )}

  <div style="display:flex;flex-wrap:wrap;gap:4px;">
    {site.tags.slice(0, 3).map(tag => (
      <span style="font-family:'Courier New',monospace;font-size:0.55rem;letter-spacing:0.1em;text-transform:uppercase;color:#484038;border:1px solid #1e1e1e;padding:1px 5px;">{tag}</span>
    ))}
  </div>

  <div style="display:flex;align-items:center;justify-content:space-between;padding-top:8px;border-top:1px solid #1e1e1e;">
    <span style="font-family:'Courier New',monospace;font-size:0.65rem;color:#484038;letter-spacing:0.05em;">
      {"★".repeat(stars)}{"☆".repeat(5 - stars)} <span style="color:#2a2a2a;">{site.rating}</span>
    </span>
    <a href={site.url} target="_blank" rel="noopener noreferrer"
      style="font-family:'Courier New',monospace;font-size:0.62rem;letter-spacing:0.12em;text-transform:uppercase;color:#c8b898;text-decoration:none;border-bottom:1px solid #444;"
      onmouseover="this.style.color='#e8e0d0'" onmouseout="this.style.color='#c8b898'"
      aria-label={`Visit ${site.title}`}
    >Visit →</a>
  </div>
</article>
