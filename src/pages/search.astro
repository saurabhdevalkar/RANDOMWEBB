---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import AdSlot from '../components/AdSlot.astro';
import { websites } from '../data/websites';
import { categories } from '../data/categories';

// Pass data to client as JSON
const sitesJSON = JSON.stringify(websites);
const catsJSON = JSON.stringify(categories);
---

<Layout
  title="Search Websites — Randomwebb"
  description="Search our curated database of random, weird, fun, and useful websites. Find exactly what you're looking for or discover something new."
>
  <Navbar />

  <div class="container-main py-12">
    <!-- Breadcrumb -->
    <nav aria-label="Breadcrumb" class="mb-8">
      <ol class="flex items-center gap-2 text-xs font-mono text-(--color-muted)">
        <li><a href="/" class="hover:text-(--color-ink) transition-colors">Home</a></li>
        <li>/</li>
        <li class="text-(--color-body-strong)">Search</li>
      </ol>
    </nav>

    <h1 class="section-title mb-2">Search Websites</h1>
    <p class="text-(--color-muted) mb-8">Search through {websites.length}+ curated websites</p>

    <!-- Search input -->
    <div class="relative max-w-2xl mb-6">
      <svg class="absolute left-4 top-1/2 -translate-y-1/2 text-(--color-muted)" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
      </svg>
      <input
        id="search-input"
        type="search"
        placeholder="Search by name, description, or tag..."
        autocomplete="off"
        class="w-full pl-12 pr-4 py-3.5 bg-(--color-surface-card) border border-(--color-hairline) rounded-xl text-(--color-ink) placeholder:text-(--color-muted) focus:outline-none focus:border-(--color-accent) transition-colors"
      />
    </div>

    <!-- Category filter pills -->
    <div id="cat-filters" class="flex flex-wrap gap-2 mb-8">
      <button data-cat="" class="cat-btn tag-badge py-2 px-4 cursor-pointer hover:text-(--color-ink) transition-colors active-cat">All</button>
      {categories.map(cat => (
        <button data-cat={cat.slug} class="cat-btn tag-badge py-2 px-4 cursor-pointer hover:text-(--color-ink) transition-colors">
          {cat.icon} {cat.name}
        </button>
      ))}
    </div>

    <AdSlot class="mb-8" />

    <!-- Results -->
    <div id="results-count" class="text-sm text-(--color-muted) mb-4"></div>
    <div id="results-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4"></div>
    <p id="no-results" class="hidden text-center py-20 text-(--color-muted)">No websites found. Try a different search term.</p>
  </div>

  <Footer />
</Layout>

<script define:vars={{ sitesJSON, catsJSON }}>
  const sites = JSON.parse(sitesJSON);
  const categories = JSON.parse(catsJSON);
  const grid = document.getElementById('results-grid');
  const countEl = document.getElementById('results-count');
  const noResults = document.getElementById('no-results');
  const searchInput = document.getElementById('search-input');
  const catBtns = document.querySelectorAll('.cat-btn');

  let query = '';
  let activeCat = '';

  function getCatIcon(slug) {
    return categories.find(c => c.slug === slug)?.icon ?? '🌐';
  }

  function renderCard(site) {
    const stars = Math.round(site.rating);
    const filledStar = '★';
    const emptyStar = '☆';
    return `
      <article class="card-base p-5 flex flex-col gap-3">
        <div class="flex items-start gap-2">
          <span class="text-xl shrink-0">${getCatIcon(site.category)}</span>
          <div class="min-w-0 flex-1">
            <h3 class="font-semibold text-(--color-ink) text-sm truncate">${site.title}</h3>
            <p class="text-xs text-(--color-muted) font-mono truncate">${new URL(site.url).hostname}</p>
          </div>
          ${site.trending ? '<span class="tag-badge shrink-0">🔥 Hot</span>' : ''}
        </div>
        <p class="text-sm text-(--color-body) line-clamp-2 leading-relaxed">${site.description}</p>
        <div class="flex flex-wrap gap-1">
          ${site.tags.slice(0, 3).map(t => `<span class="tag-badge">${t}</span>`).join('')}
        </div>
        <div class="flex items-center justify-between mt-auto pt-2 border-t border-(--color-hairline)">
          <span class="text-sm text-(--color-warning)">${filledStar.repeat(stars)}${emptyStar.repeat(5 - stars)} <span class="text-xs text-(--color-muted)">${site.rating}</span></span>
          <a href="${site.url}" target="_blank" rel="noopener noreferrer" class="text-xs font-mono uppercase tracking-wider text-(--color-accent) hover:text-(--color-link) transition-colors">Visit ↗</a>
        </div>
      </article>
    `;
  }

  function render() {
    const q = query.toLowerCase();
    const filtered = sites.filter(s => {
      const matchCat = !activeCat || s.category === activeCat;
      const matchQ = !q || s.title.toLowerCase().includes(q) || s.description.toLowerCase().includes(q) || s.tags.some(t => t.includes(q));
      return matchCat && matchQ;
    });

    grid.innerHTML = filtered.map(renderCard).join('');
    countEl.textContent = `${filtered.length} website${filtered.length !== 1 ? 's' : ''} found`;
    noResults.classList.toggle('hidden', filtered.length > 0);
  }

  // Initial render
  render();

  searchInput?.addEventListener('input', e => {
    query = e.target.value;
    render();
  });

  catBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      activeCat = btn.dataset.cat ?? '';
      catBtns.forEach(b => b.classList.remove('active-cat', 'border-(--color-accent)', 'text-(--color-ink)'));
      btn.classList.add('active-cat', 'text-(--color-ink)');
      render();
    });
  });

  // Handle URL query param
  const params = new URLSearchParams(window.location.search);
  const urlQ = params.get('q');
  if (urlQ && searchInput) {
    searchInput.value = urlQ;
    query = urlQ;
    render();
  }
</script>

<style>
  .active-cat { border-color: var(--color-accent); color: var(--color-ink); }
</style>
