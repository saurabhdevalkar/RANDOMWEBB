---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';
import WebsiteCard from '../components/WebsiteCard.astro';
import SpinWheel from '../components/SpinWheel.astro';
import FeaturedSite from '../components/FeaturedSite.astro';
import AdSlot from '../components/AdSlot.astro';
import { websites, getTrendingWebsites, getRecentlyAdded, getFeaturedWebsite } from '../data/websites';
import { categories } from '../data/categories';

const trending = getTrendingWebsites().slice(0, 8);
const recent = getRecentlyAdded().slice(0, 6);
const featured = getFeaturedWebsite();

const schema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Randomwebb',
  url: 'https://randomwebb.com',
  description: 'Discover random, weird, fun, and hidden websites from across the internet. The best random website generator — cure boredom instantly.',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://randomwebb.com/search?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<Layout
  title="Randomwebb — Fun Websites, Weird Sites & Random Website Generator"
  description="Discover the most fun, weird, cool, and hidden websites on the internet. The best random website generator to cure boredom instantly. 300+ curated sites across gaming, AI tools, retro, educational, and more."
  keywords="fun websites, websites when bored, im bored, cool websites, weird websites, random websites, random website generator, websites to cure boredom, interesting websites, best websites, hidden gems internet, websites to waste time, website roulette, surprise me website, internet rabbit hole, strange websites, funny websites, addictive websites, entertaining websites, awesome websites, unique websites, bizarre websites, boredom buster, things to do when bored, free fun websites, best online distractions, productive websites, ai tools, gaming websites, retro websites, browser games, cool sites, internet discoveries, must visit websites, secret websites, mind blowing websites, interactive websites, relaxing websites, weird corners of the internet, underrated websites, coolest websites ever, websites everyone should know, fun websites 2026, cool websites 2026, weird websites 2026, random websites 2026"
  schema={schema}
>
  <Navbar />

  <!-- HERO -->
  <section style="padding:64px 1.5rem 56px;text-align:center;max-width:960px;margin:0 auto;border-bottom:1px solid #1e1e1e;">
    <div style="font-family:'Courier New',monospace;font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:#484038;margin-bottom:20px;">
      {websites.length}+ Curated Websites &nbsp;·&nbsp; Updated Regularly
    </div>

    <h1 style="font-family:'Special Elite',serif;font-size:clamp(2.4rem,7vw,4.5rem);color:#e8e0d0;letter-spacing:0.04em;line-height:1.1;margin:0 0 20px;">
      Explore the<br/>
      <span style="color:#c8b898;">Weird &amp; Wonderful</span><br/>
      Internet
    </h1>

    <p style="font-family:'Courier New',monospace;font-size:0.8rem;color:#706860;max-width:480px;margin:0 auto 36px;line-height:1.8;letter-spacing:0.03em;">
      Discover random, weird, fun, useful, and hidden-gem websites.<br/>Every click is a new adventure.
    </p>

    <div style="display:flex;flex-direction:column;align-items:center;gap:12px;">
      <button
        id="random-btn"
        style="font-family:'Special Elite',serif;font-size:2rem;letter-spacing:0.08em;text-transform:uppercase;padding:24px 80px;background:#e8e0d0;color:#0a0a0a;border:2px solid #e8e0d0;cursor:pointer;transition:all 0.15s;"
        onmouseover="this.style.background='#0a0a0a';this.style.color='#e8e0d0'"
        onmouseout="this.style.background='#e8e0d0';this.style.color='#0a0a0a'"
        aria-label="Take me to a random website"
      >
        Take Me Somewhere Random
      </button>
      <a href="/search"
        style="font-family:'Courier New',monospace;font-size:0.65rem;letter-spacing:0.15em;text-transform:uppercase;color:#484038;text-decoration:none;padding:4px 0;border-bottom:1px solid #2a2a2a;"
        onmouseover="this.style.color='#c8b898';this.style.borderColor='#c8b898'"
        onmouseout="this.style.color='#484038';this.style.borderColor='#2a2a2a'"
      >
        Search Websites
      </a>
    </div>

    <!-- Stats -->
    <div style="display:flex;align-items:center;justify-content:center;gap:32px;margin-top:40px;font-family:'Courier New',monospace;font-size:0.62rem;letter-spacing:0.15em;text-transform:uppercase;color:#484038;">
      <div style="text-align:center;">
        <div style="font-size:1.4rem;color:#c8b898;font-family:'Special Elite',serif;letter-spacing:0.05em;">{websites.length}+</div>
        <div>Websites</div>
      </div>
      <div style="width:1px;height:32px;background:#1e1e1e;"></div>
      <div style="text-align:center;">
        <div style="font-size:1.4rem;color:#c8b898;font-family:'Special Elite',serif;letter-spacing:0.05em;">{categories.length}</div>
        <div>Categories</div>
      </div>
      <div style="width:1px;height:32px;background:#1e1e1e;"></div>
      <div style="text-align:center;">
        <div style="font-size:1.4rem;color:#c8b898;font-family:'Special Elite',serif;letter-spacing:0.05em;">Free</div>
        <div>Always</div>
      </div>
    </div>
  </section>

  <!-- AD -->
  <div style="max-width:960px;margin:0 auto;padding:20px 1.5rem;">
    <AdSlot />
  </div>

  <!-- CATEGORIES -->
  <section style="max-width:960px;margin:0 auto;padding:0 1.5rem 48px;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px;">
      <h2 style="font-family:'Special Elite',serif;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;color:#e8e0d0;border-bottom:1px solid #2a2a2a;padding-bottom:6px;margin:0;">Browse by Category</h2>
      <a href="/search" style="font-family:'Courier New',monospace;font-size:0.6rem;letter-spacing:0.12em;text-transform:uppercase;color:#484038;text-decoration:none;"
        onmouseover="this.style.color='#c8b898'" onmouseout="this.style.color='#484038'">All →</a>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(140px,1fr));gap:1px;background:#1e1e1e;border:1px solid #1e1e1e;">
      {categories.map(cat => (
        <a href={`/category/${cat.slug}`}
          style="display:flex;align-items:center;gap:8px;padding:12px;background:#161616;text-decoration:none;transition:background 0.1s;"
          onmouseover="this.style.background='#1e1e1e'" onmouseout="this.style.background='#161616'"
        >
          <span style="font-size:1rem;filter:grayscale(1);opacity:0.6;">{cat.icon}</span>
          <div>
            <div style="font-family:'Special Elite',serif;font-size:0.75rem;color:#c8b898;letter-spacing:0.03em;">{cat.name}</div>
            <div style="font-family:'Courier New',monospace;font-size:0.55rem;color:#484038;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;max-width:100px;">{cat.description}</div>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- SPIN WHEEL + FEATURED -->
  <section style="background:#111111;border-top:1px solid #1e1e1e;border-bottom:1px solid #1e1e1e;padding:48px 1.5rem;">
    <div style="max-width:960px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:48px;align-items:start;">
      <div style="display:flex;flex-direction:column;align-items:center;">
        <h2 style="font-family:'Special Elite',serif;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;color:#e8e0d0;border-bottom:1px solid #2a2a2a;padding-bottom:6px;margin:0 0 6px;width:100%;text-align:left;">Spin the Wheel</h2>
        <p style="font-family:'Courier New',monospace;font-size:0.65rem;color:#484038;margin:0 0 20px;align-self:flex-start;letter-spacing:0.05em;">Spin. Land. Discover.</p>
        <SpinWheel />
      </div>
      <div>
        <h2 style="font-family:'Special Elite',serif;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;color:#e8e0d0;border-bottom:1px solid #2a2a2a;padding-bottom:6px;margin:0 0 6px;">Daily Featured</h2>
        <p style="font-family:'Courier New',monospace;font-size:0.65rem;color:#484038;margin:0 0 20px;letter-spacing:0.05em;">One exceptional site, every day.</p>
        <FeaturedSite site={featured} />
      </div>
    </div>
  </section>

  <!-- TRENDING -->
  <section style="max-width:960px;margin:0 auto;padding:48px 1.5rem;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px;">
      <h2 style="font-family:'Special Elite',serif;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;color:#e8e0d0;border-bottom:1px solid #2a2a2a;padding-bottom:6px;margin:0;">Trending Now</h2>
      <span style="font-family:'Courier New',monospace;font-size:0.58rem;color:#2a2a2a;letter-spacing:0.1em;text-transform:uppercase;">This Week</span>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1px;background:#1e1e1e;border:1px solid #1e1e1e;">
      {trending.map(site => <WebsiteCard site={site} />)}
    </div>
  </section>

  <!-- AD -->
  <div style="max-width:960px;margin:0 auto;padding:0 1.5rem 32px;">
    <AdSlot />
  </div>

  <!-- RECENTLY ADDED -->
  <section style="max-width:960px;margin:0 auto;padding:0 1.5rem 48px;">
    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:20px;">
      <h2 style="font-family:'Special Elite',serif;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;color:#e8e0d0;border-bottom:1px solid #2a2a2a;padding-bottom:6px;margin:0;">Recently Added</h2>
      <span style="font-family:'Courier New',monospace;font-size:0.58rem;color:#2a2a2a;letter-spacing:0.1em;text-transform:uppercase;">Fresh Picks</span>
    </div>
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1px;background:#1e1e1e;border:1px solid #1e1e1e;">
      {recent.map(site => <WebsiteCard site={site} />)}
    </div>
  </section>

  <!-- CTA -->
  <section style="border-top:1px solid #1e1e1e;border-bottom:1px solid #1e1e1e;padding:60px 1.5rem;text-align:center;background:#111111;">
    <div style="max-width:520px;margin:0 auto;">
      <div style="font-family:'Courier New',monospace;font-size:0.58rem;letter-spacing:0.25em;text-transform:uppercase;color:#484038;margin-bottom:16px;">Ready for a Surprise?</div>
      <h2 style="font-family:'Special Elite',serif;font-size:clamp(1.6rem,4vw,2.4rem);color:#e8e0d0;letter-spacing:0.04em;margin:0 0 12px;">Click. Explore. Discover.</h2>
      <p style="font-family:'Courier New',monospace;font-size:0.7rem;color:#706860;margin:0 0 28px;line-height:1.8;">Every click takes you somewhere new from our curated collection.</p>
      <button id="random-btn-2"
        style="font-family:'Special Elite',serif;font-size:2rem;letter-spacing:0.08em;text-transform:uppercase;padding:24px 80px;background:#e8e0d0;color:#0a0a0a;border:2px solid #e8e0d0;cursor:pointer;transition:all 0.15s;"
        onmouseover="this.style.background='#0a0a0a';this.style.color='#e8e0d0'"
        onmouseout="this.style.background='#e8e0d0';this.style.color='#0a0a0a'"
      >
        Take Me Somewhere Random
      </button>
    </div>
  </section>

  <!-- SEO TEXT BLOCK -->
  <section style="max-width:960px;margin:0 auto;padding:48px 1.5rem;border-top:1px solid #1e1e1e;">
    <h2 style="font-family:'Special Elite',serif;font-size:1rem;letter-spacing:0.12em;text-transform:uppercase;color:#e8e0d0;border-bottom:1px solid #2a2a2a;padding-bottom:6px;margin:0 0 20px;">The Best Fun Websites to Cure Boredom Online</h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(280px,1fr));gap:24px;font-family:'Courier New',monospace;font-size:0.7rem;color:#484038;line-height:1.8;">
      <div>
        <p>Looking for <strong style="color:#706860;">fun websites</strong> when you're bored? Randomwebb is the internet's best <strong style="color:#706860;">random website generator</strong> — a curated directory of the coolest, weirdest, and most entertaining sites online. Whether you need <strong style="color:#706860;">websites to cure boredom</strong>, kill time, or go down an internet rabbit hole, we have you covered.</p>
        <p style="margin-top:12px;">Our collection spans <strong style="color:#706860;">weird websites</strong>, <strong style="color:#706860;">cool websites</strong>, <strong style="color:#706860;">hidden gems</strong>, free browser games, AI tools, retro internet nostalgia, educational interactive experiences, and more. Every category is hand-curated — no spam, no filler.</p>
      </div>
      <div>
        <p>Tired of the same sites? Hit <strong style="color:#706860;">"Take Me Somewhere Random"</strong> for instant website roulette — a surprise destination from our 300+ curated list. It's the best <strong style="color:#706860;">boredom buster</strong> on the internet. Spin the wheel, land on a category, and discover something new.</p>
        <p style="margin-top:12px;">From <strong style="color:#706860;">addictive browser games</strong> and <strong style="color:#706860;">interactive websites</strong> to <strong style="color:#706860;">relaxing</strong> and <strong style="color:#706860;">satisfying sites</strong>, Randomwebb covers every corner of the internet worth visiting. Bookmark us — you'll be back.</p>
      </div>
    </div>
    <!-- Hidden keyword cloud for long-tail SEO -->
    <div style="margin-top:24px;display:flex;flex-wrap:wrap;gap:6px;">
      {['fun websites','cool websites','weird websites','random websites','websites when bored','im bored','boredom cure','internet rabbit hole','random website generator','website roulette','hidden gems','free browser games','ai tools','retro websites','educational websites','gaming websites','interactive websites','relaxing websites','weird internet','cool internet sites','must visit websites','internet discoveries','boredom buster','things to do online','fun things online','websites to waste time','entertaining websites','addictive websites','unique websites','bizarre websites','secret websites','mind blowing websites','creative websites','internet playground','digital playground','fun websites 2026','weird websites 2026','cool websites 2026'].map(kw => (
        <a href={`/search?q=${encodeURIComponent(kw)}`} style="font-family:'Courier New',monospace;font-size:0.55rem;letter-spacing:0.08em;color:#2a2a2a;text-decoration:none;border:1px solid #1e1e1e;padding:2px 6px;"
          onmouseover="this.style.color='#706860'" onmouseout="this.style.color='#2a2a2a'">{kw}</a>
      ))}
    </div>
  </section>

  <Footer />
</Layout>

